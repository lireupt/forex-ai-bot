# ============================================================
# API KEYS
# ============================================================

ANTHROPIC_API_KEY=sk-ant-PLACEHOLDER
GROQ_API_KEY=PLACEHOLDER
OANDA_API_KEY=PLACEHOLDER
OANDA_ACCOUNT_ID=PLACEHOLDER
OANDA_ENVIRONMENT=practice

ALPHA_VANTAGE_KEY=PLACEHOLDER
MARKETAUX_KEY=PLACEHOLDER

TWELVEDATA_API_KEY=PLACEHOLDER

# ============================================================
# AI CONFIGURATION
# ============================================================

AI_PROVIDER=groq

# Confiança mínima para aceitar voto da IA (0-100)
AI_VOTE_MIN_CONFIDENCE=35

# Confiança mínima final para executar trade (0-1)
MIN_CONFIDENCE_TO_TRADE=0.55

# Cache IA
AI_CACHE_DAILY=True

# Número de tentativas em caso de falha da API
AI_MAX_RETRIES=3
AI_RETRY_BACKOFF_SECONDS=5

# ============================================================
# EXECUTION MODE
# ============================================================

# NUNCA mudar para False sem revisão completa do código
DRY_RUN=True

# ============================================================
# ACCOUNT / RISK MANAGEMENT
# ============================================================

ACCOUNT_BALANCE=1000

# Percentagem de risco por trade
RISK_PER_TRADE_PERCENT=1

# Fallback caso ATR esteja indisponível
DEFAULT_STOP_LOSS_PIPS=30
DEFAULT_TAKE_PROFIT_PIPS=60

# ============================================================
# ATR DYNAMIC SL/TP
# ============================================================

USE_ATR_SL_TP=True

ATR_SL_MULT=1.5
ATR_TP_MULT=3.0

ATR_MIN_SL_PIPS=12
ATR_MAX_SL_PIPS=60

# ============================================================
# COMBINED SCORE THRESHOLDS
# ============================================================

COMBINED_BUY_THRESHOLD=0.42
COMBINED_SELL_THRESHOLD=-0.42

# Pesos do scoring combinado (devem somar 1.0)
AI_WEIGHT=0.30
TECHNICAL_WEIGHT=0.55
NEWS_WEIGHT=0.15

# ============================================================
# GATING
# ============================================================

GATING_MODE=score

# --- Adaptive Risk ---
ADAPTIVE_BASE_MIN_CONFIDENCE=0.45
ADAPTIVE_MIN_FLOOR=0.35
ADAPTIVE_MIN_CEILING=0.65
MAX_SPREAD_PIPS=2.5
ATR_EXTREME_PIPS=35.0
BLOCK_EXTREME_NEWS_RISK=False

# ============================================================
# OPERATIONAL CALIBRATION
# ============================================================

# Horário operacional (UTC)
OPERATIONAL_TRADE_START_HOUR=7
OPERATIONAL_TRADE_END_HOUR=18

# Cooldown entre trades
COOLDOWN_MINUTES=90

# Máximo de sinais na mesma direção por dia
MAX_DIRECTION_SIGNALS_PER_DAY=4

# Ignorar decisões duplicadas
DEDUP_WINDOW_MINUTES=50

ALLOW_BUY=True
ALLOW_SELL=True

# ============================================================
# NEWS / EVENTS FILTERS
# ============================================================

BLOCK_NEAR_HIGH_IMPACT_EVENTS=True

# Minutos antes/depois do evento
EVENT_BLOCK_WINDOW_MINUTES=120

# ============================================================
# MACRO ECONOMIC CALENDAR FILTER
# ============================================================

USE_ECONOMIC_CALENDAR_FILTER=True
MACRO_HIGH_IMPACT_BLOCK_BEFORE_MINUTES=30
MACRO_HIGH_IMPACT_BLOCK_AFTER_MINUTES=30
MACRO_MEDIUM_IMPACT_CONFIDENCE_FACTOR=0.8
MACRO_MEDIUM_IMPACT_WINDOW_MINUTES=20

# ============================================================
# ADX TREND FILTER
# ============================================================

ADX_TREND_FILTER_ENABLED=False

# ============================================================
# CACHE SETTINGS
# ============================================================

USE_CACHE=True
FORCE_REFRESH=False

NEWS_CACHE_HOURS=12
CALENDAR_CACHE_HOURS=12
PRICE_CACHE_MINUTES=60

# ============================================================
# IA AGREGADORA
# ============================================================

AI_AGGREGATOR_ENABLED=False
AI_AGGREGATOR_MODE=shadow

# ============================================================
# WEEKEND MODE
# ============================================================

WEEKEND_MODE_ENABLED=True
WEEKEND_MODE_UPDATE_NEWS=True
WEEKEND_MODE_UPDATE_CALENDAR=True
WEEKEND_MODE_EXPORT_LOGS=True

# ============================================================
# WEEKLY MARKET PREPARATION
# ============================================================

WEEKLY_MARKET_PREP_ENABLED=True
WEEKLY_MARKET_PREP_WEEKDAY=6
WEEKLY_MARKET_PREP_HOUR_UTC=21
WEEKLY_MARKET_PREP_LOOKBACK_HOURS=72
WEEKLY_MARKET_PREP_CALENDAR_DAYS=7
WEEKLY_MARKET_PREP_USE_AI=True

# ============================================================
# ROLLING MARKET CONTEXT (Camada 5)
# ============================================================

ROLLING_CONTEXT_ENABLED=True
ROLLING_CONTEXT_UPDATE_EVERY_CYCLE=False
ROLLING_CONTEXT_LOOKBACK_HOURS=4
ROLLING_CONTEXT_MAX_PREVIOUS_SUMMARY_CHARS=400
ROLLING_CONTEXT_MIN_INTERVAL_HOURS=6

# ============================================================
# TRADE MONITOR (processo separado)
# ============================================================

# Executar em paralelo com o cron:
# python monitor_trades.py >> logs/monitor.log 2>&1
TRADE_MONITOR_INTERVAL_SECONDS=30

# ============================================================
# CRON (referência)
# 5 * * * * cd /root/forex-ai-bot && /root/forex-ai-bot/venv/bin/python main.py >> logs/cron.log 2>&1
# ============================================================

# ============================================================
# FASE B — REPLAY DE IA HISTÓRICO (scripts/import_historical_news.py,
# scripts/build_historical_ai_cache.py)
#
# Chaves DEDICADAS, isoladas da quota diária do bot ao vivo (nunca
# reaproveitam ALPHA_VANTAGE_KEY / GROQ_API_KEY acima). Opcionais — só
# a primeira (sem sufixo) é obrigatória para cada script; acrescenta
# _2, _3, ... sequenciais para mais chaves/contas e multiplicar o
# orçamento diário efetivo.
# ============================================================

GROQ_API_KEY_HISTORICAL=PLACEHOLDER

ALPHA_VANTAGE_KEY_HISTORICAL=PLACEHOLDER
